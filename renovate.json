{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["helpers:pinGitHubActionDigests", ":configMigration", "group:monorepos"],
  "automerge": true,
  "automergeType": "pr",
  "dependencyDashboard": true,
  "minimumReleaseAge": "7 days",
  "platformAutomerge": true,
  "poetry": {
    "enabled": false
  },
  "prConcurrentLimit": 1,
  "prHourlyLimit": 0,
  "pre-commit": {
    "enabled": true
  },
  "rangeStrategy": "pin"
}
